{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "outDir": ".tmp/tests",
    "rootDir": "src"
  },
  "include": ["src/**/*.test.ts", "src/rules.ts", "src/issues.ts"]
}
